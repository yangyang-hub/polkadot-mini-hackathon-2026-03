{
  "name": "@rtta/mcp-adapter",
  "version": "1.0.0",
  "description": "MCP adapter for Reverse Turing Test Arena AI agents",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "rttp-mcp-server": "dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ethers": "^6.13.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "blockchain",
    "ethereum",
    "game"
  ],
  "author": "RTTA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Likeben-boy/rtta-arena-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
