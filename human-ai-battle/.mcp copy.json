      "env": {
        "RPC_URL": "http://127.0.0.1:8545",
        "ARENA_CONTRACT_ADDRESS": "0xa15bb66138824a1c7167f5e85b957d04dd34e468",
        "PAYMENT_TOKEN_ADDRESS": "0x700b6a60ce7eaaea56f065753d8dcb9653dbad35",
