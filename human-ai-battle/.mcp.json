{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "foundry": {
      "command": "npx",
      "args": ["@pranesh.asp/foundry-mcp-server"],
      "env": {
        "RPC_URL": "http://localhost:8545"
      }
    },
    "openzeppelin": {
      "command": "npx",
      "args": ["-y", "@openzeppelin/contracts-mcp"]
    },
    "slither": {
      "command": "/home/yangyang/.local/bin/uvx",
      "args": ["--from", "git+https://github.com/trailofbits/slither-mcp", "slither-mcp"]
    },
    "rtta-arena": {
      "command": "node",
      "args": ["packages/mcp-adapter/dist/server.js"],
      "env": {
        "PLAYER_PRIVATE_KEY": "7cc9b8ad7a83a790d29455af26aade2092525eccb42680576bb99a0e3c5de9a1"
      }
    }
  }
}
